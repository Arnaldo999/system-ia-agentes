# ─────────────────────────────────────────────────────────────────────────────
# .env.example — system-ia-agentes
# ─────────────────────────────────────────────────────────────────────────────
# Copiá este archivo como .env y completá con tus valores reales.
# NUNCA commitees el .env real — está en .gitignore.
#
# Verificar entorno SIN hacer llamadas a APIs:
#   cp .env.example .env
#   # (editar .env con los valores reales)
#   python scripts/manual_tests/test_gastro_env.py   # worker gastronómico
#   python scripts/manual_tests/test_social_env.py   # worker social (Meta/IG)
#
# ⚠️  IMPORTANTE: cada clave debe aparecer UNA SOLA VEZ en este archivo.
#     Si una var es compartida entre workers (ej: AIRTABLE_BASE_ID),
#     definirla una vez — el worker que la necesite la leerá del entorno.
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# IA — Modelos de lenguaje
# Requerido: ambos workers
# ══════════════════════════════════════════════════════════════════════════════

GEMINI_API_KEY=AIzaSy_COMPLETAR

# Opcional: solo para transcripción de audio con Whisper (worker gastronómico).
# Si no se define, la función de audio queda deshabilitada.
OPENAI_API_KEY=sk-COMPLETAR


# ══════════════════════════════════════════════════════════════════════════════
# Airtable
# AIRTABLE_API_KEY  → worker gastronómico
# AIRTABLE_TOKEN    → worker social (puede ser el mismo PAT)
# AIRTABLE_BASE_ID  → compartido (un entorno = una base activa)
# AIRTABLE_TABLE_ID → worker social (ID de la tabla de comentarios/respuestas)
# ══════════════════════════════════════════════════════════════════════════════

AIRTABLE_API_KEY=patCOMPLETAR
AIRTABLE_TOKEN=patCOMPLETAR

# ID de la base Airtable (formato: appXXXXXXXXXXXXXX)
AIRTABLE_BASE_ID=appCOMPLETAR

# ID de la tabla del worker social (formato: tblXXXXXXXXXXXXXX)
AIRTABLE_TABLE_ID=tblCOMPLETAR


# ══════════════════════════════════════════════════════════════════════════════
# Evolution API — WhatsApp
# Requerido: ambos workers
# ══════════════════════════════════════════════════════════════════════════════

EVOLUTION_API_URL=https://TU-INSTANCIA.ejemplo.com
EVOLUTION_INSTANCE=nombre-instancia
EVOLUTION_API_KEY=COMPLETAR


# ══════════════════════════════════════════════════════════════════════════════
# Worker gastronómico — notificaciones al dueño
# ══════════════════════════════════════════════════════════════════════════════

# Número del dueño (formato internacional sin +, ej: 5493812345678)
NUMERO_DUENO=549COMPLETAR


# ══════════════════════════════════════════════════════════════════════════════
# Meta / Facebook / Instagram — Cliente base (Mica / AgenciaSystemIA)
# Requerido: worker social
# ══════════════════════════════════════════════════════════════════════════════

# System User token permanente (desde business.facebook.com → System Users)
META_ACCESS_TOKEN=COMPLETAR

# ID de la página de Facebook
FACEBOOK_PAGE_ID=COMPLETAR

# ID de la cuenta de Instagram Business
IG_BUSINESS_ACCOUNT_ID=COMPLETAR

# Token de verificación del webhook Meta (string secreto, recordarlo)
META_WEBHOOK_VERIFY_TOKEN=COMPLETAR


# ══════════════════════════════════════════════════════════════════════════════
# Meta — Cliente 2 (System IA / Arnaldo)
# Opcional: solo si está configurado en Easypanel
# ══════════════════════════════════════════════════════════════════════════════

CLIENT_2_META_TOKEN=COMPLETAR
CLIENT_2_PAGE_ID=COMPLETAR
CLIENT_2_IG_ID=COMPLETAR


# ══════════════════════════════════════════════════════════════════════════════
# Meta — Cliente 3 (próximo cliente)
# Opcional: agregar cuando corresponda
# ══════════════════════════════════════════════════════════════════════════════

CLIENT_3_META_TOKEN=COMPLETAR
CLIENT_3_PAGE_ID=COMPLETAR
CLIENT_3_IG_ID=COMPLETAR
