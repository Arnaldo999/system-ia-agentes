# ─────────────────────────────────────────────────────────────────────────────
# .env.example — system-ia-agentes
# ─────────────────────────────────────────────────────────────────────────────
# Copiá este archivo como .env y completá con tus valores reales.
# NUNCA commitees el .env real — está en .gitignore.
#
# Uso:
#   cp .env.example .env
#   # editar .env con los valores reales
#   python scripts/manual_tests/test_gastro_env.py   # verificar worker gastronómico
#   python scripts/manual_tests/test_social_env.py   # verificar worker social
# ─────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# IA — Modelos de lenguaje
# ══════════════════════════════════════════════════════════════════════════════

# Google Gemini (requerido por ambos workers)
GEMINI_API_KEY=AIzaSy_REEMPLAZAR_CON_TU_CLAVE

# OpenAI — solo para transcripción de audio con Whisper (worker gastronómico)
# Opcional: si no se define, la transcripción de audio queda deshabilitada.
OPENAI_API_KEY=sk-REEMPLAZAR_CON_TU_CLAVE


# ══════════════════════════════════════════════════════════════════════════════
# Airtable — Worker gastronómico
# ══════════════════════════════════════════════════════════════════════════════

# API Key de Airtable (personal access token)
AIRTABLE_API_KEY=patREEMPLAZAR_CON_TU_TOKEN

# ID de la base de datos Airtable del restaurante
# Formato: appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appREEMPLAZAR_CON_TU_BASE

# Número del dueño para notificaciones (formato internacional, sin +)
# Ejemplo: 5493812345678
NUMERO_DUENO=5493812345678


# ══════════════════════════════════════════════════════════════════════════════
# Airtable — Worker social (Meta / Instagram)
# ══════════════════════════════════════════════════════════════════════════════

# Token de Airtable (puede ser el mismo que AIRTABLE_API_KEY)
AIRTABLE_TOKEN=patREEMPLAZAR_CON_TU_TOKEN

# Base y tabla del cliente base (Mica / AgenciaSystemIA)
AIRTABLE_BASE_ID=appREEMPLAZAR_CON_TU_BASE
AIRTABLE_TABLE_ID=tblREEMPLAZAR_CON_TU_TABLA


# ══════════════════════════════════════════════════════════════════════════════
# Evolution API — WhatsApp (compartido entre workers)
# ══════════════════════════════════════════════════════════════════════════════

# URL base de la instancia de Evolution API
EVOLUTION_API_URL=https://TU-INSTANCIA.ejemplo.com

# Nombre de la instancia configurada en Evolution API
EVOLUTION_INSTANCE=nombre-instancia

# API Key de Evolution API
EVOLUTION_API_KEY=REEMPLAZAR_CON_TU_KEY


# ══════════════════════════════════════════════════════════════════════════════
# Meta / Facebook / Instagram — Cliente base (Mica)
# ══════════════════════════════════════════════════════════════════════════════

# System User token permanente (desde business.facebook.com)
META_ACCESS_TOKEN=REEMPLAZAR_CON_TU_TOKEN_PERMANENTE

# ID de la página de Facebook
FACEBOOK_PAGE_ID=REEMPLAZAR_CON_TU_PAGE_ID

# ID de la cuenta de Instagram Business
IG_BUSINESS_ACCOUNT_ID=REEMPLAZAR_CON_TU_IG_ID

# Token de verificación del webhook de Meta (string arbitrario, recordarlo)
META_WEBHOOK_VERIFY_TOKEN=REEMPLAZAR_CON_UN_STRING_SECRETO


# ══════════════════════════════════════════════════════════════════════════════
# Meta — Cliente 2 (System IA / Arnaldo)
# ══════════════════════════════════════════════════════════════════════════════

CLIENT_2_META_TOKEN=REEMPLAZAR
CLIENT_2_PAGE_ID=REEMPLAZAR
CLIENT_2_IG_ID=REEMPLAZAR


# ══════════════════════════════════════════════════════════════════════════════
# Meta — Cliente 3 (próximo cliente)
# ══════════════════════════════════════════════════════════════════════════════

CLIENT_3_META_TOKEN=REEMPLAZAR
CLIENT_3_PAGE_ID=REEMPLAZAR
CLIENT_3_IG_ID=REEMPLAZAR
