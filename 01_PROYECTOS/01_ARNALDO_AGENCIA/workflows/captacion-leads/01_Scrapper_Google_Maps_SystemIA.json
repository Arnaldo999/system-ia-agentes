        "jsCode": "// Limpia URLs removiendo www. y normalizando\nconst items = $input.all();\n\nreturn items.map(item => {\n  const original = item.json.websiteUri || '';\n  const cleaned = original.replace(/^https?:\\/\\/(www\\.)?/i, 'https://');\n  const nombre = item.json.displayName?.text || '';\n  return {\n    json: {\n      ...item.json,\n      websiteUri: cleaned,\n      nombre: nombre\n    }\n  };\n});"
      },
