    {
      "parameters": {
        "jsCode": "const demo = $input.first().json.demo_activa;\nconst body_original = $input.first().json.body_original;\n\nconst demos = {\n  'conecta':     'https://sytem-ia-pruebas-n8n.6g0gdj.easypanel.host/webhook/4973a60b-fbc7-4499-9fce-b76c25785570',\n  'tienda':      'https://sytem-ia-pruebas-n8n.6g0gdj.easypanel.host/webhook/tienda-ropa',\n  'restaurante': 'https://sytem-ia-pruebas-n8n.6g0gdj.easypanel.host/webhook/webhook/automatizacion-restaurantes',\n  'citas':       'https://sytem-ia-pruebas-n8n.6g0gdj.easypanel.host/webhook/agendamiento-citas',\n  'redes':       null\n};\n\nconst url = demos[demo];\nif (url === undefined) return [];  // demo key desconocida\nif (url === null) return [];       // en construcción, no rutear\n\nreturn [{ json: { demo_url: url, body_original } }];"
      },
