    {
      "id": "co-det",
      "name": "Detectar Intención",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        420
      ],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst telefono = data.telefono;\nconst msg = data.mensaje; // already lowercase\n\nconst MENU = `¡Hola! 👋 Bienvenido a *System IA Demos*.\n\nEstas son las demos disponibles:\n1️⃣ *Conecta CRM* - gestión automatizada de clientes\n2️⃣ *Redes Sociales* - automatización de publicaciones _(en construcción)_\n3️⃣ *Tienda de Ropa* - chatbot e-commerce para WhatsApp\n4️⃣ *Restaurantes y Bares* - reservas y menú por WhatsApp\n5️⃣ *Agendamiento de Citas* - sistema de citas por WhatsApp\n\nRespondé con el número de la demo que querés probar 🚀`;\n\nconst demoMap = {\n  '1': 'conecta', 'conecta': 'conecta', 'crm': 'conecta',\n  '2': 'redes', 'redes': 'redes',\n  '3': 'tienda', 'tienda': 'tienda', 'ropa': 'tienda',\n  '4': 'restaurante', 'restaurantes': 'restaurante', 'bar': 'restaurante', 'bares': 'restaurante',\n  '5': 'citas', 'citas': 'citas', 'agenda': 'citas', 'agendamiento': 'citas'\n};\n\nconst demoKey = demoMap[msg.trim()];\n\nlet accion, texto_respuesta;\n\nif (demoKey === 'redes') {\n  accion = 'redes';\n  texto_respuesta = '🚧 La demo de *Redes Sociales* está en construcción. Pronto estará disponible.\\n\\n¿Querés probar otra demo? Respondé con un número del 1 al 5.';\n} else if (demoKey) {\n  accion = 'activar';\n  texto_respuesta = '✅ ¡Perfecto! Tu demo está activada. En unos segundos te llegará el primer mensaje 🚀';\n} else {\n  accion = 'menu';\n  texto_respuesta = MENU;\n}\n\nreturn [{ json: { telefono, accion, demo: demoKey || '', texto_respuesta } }];"
      }
    },
