# Copiar este archivo a .env y rellenar
# El .env real NO se commitea (está en .gitignore)

# === LLM provider ===
# Opciones: gemini (default, gratis hasta 1500 req/día), demo (heurística sin LLM)
LLM_PROVIDER=gemini

# === Google AI Studio (Gemini) ===
# Sacar la API key gratis en https://aistudio.google.com/apikey (30 segundos)
# El free tier permite 1500 requests/día — suficiente para 30 cultos/mes
GEMINI_API_KEY=
# Gemini 2.5 Flash (default recomendado, multimodal, free tier 500 req/día)
# Alternativas: gemini-2.5-flash-lite (más rápido, más barato), gemini-2.5-pro (más inteligente)
GEMINI_MODEL=gemini-2.5-flash

# === Freeshow (software de presentación) ===
# Activar API REST en Settings → Connections del Freeshow
FREESHOW_URL=http://localhost:5506
