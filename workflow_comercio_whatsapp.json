      "parameters": {
        "jsCode": "const fastapi = $('🧠 FastAPI — Cerebro IA').first().json;\nconst telefono = $('🔧 Normalizar Payload').first().json.telefono || '';\nconst respuesta = fastapi.respuesta || '';\nconst tipoMsg = String(fastapi.tipo_mensaje || 'texto');\nconst imagenUrl = String(fastapi.imagen_url || '');\nconst esImagen = (tipoMsg === 'imagen' && imagenUrl.length > 10) ? true : false;\nreturn [{ json: { telefono, respuesta, tipo_mensaje: tipoMsg, imagen_url: imagenUrl, es_imagen: esImagen } }];"
