      "parameters": {
        "jsCode": "const fastapi = $('🧠 FastAPI — Cerebro IA').first().json;\nconst telefono_cliente = $('🔧 Normalizar Payload').first().json.telefono || 'desconocido';\nconst accion = fastapi.accion_ejecutada || 'lead';\nconst respuesta_bot = fastapi.respuesta || '';\nconst ahora = new Date().toLocaleString('es-AR', {timeZone: 'America/Argentina/Buenos_Aires'});\nlet texto;\nif (accion === 'lead_notificado') {\n  texto = `🔥 *LEAD CALIFICADO — Casa Electrónica*\\n\\n📱 Cliente: ${telefono_cliente}\\n💬 Bot respondió: ${respuesta_bot.substring(0, 100)}...\\n⏰ ${ahora}`;\n} else {\n  texto = `📞 *CLIENTE PIDE VENDEDOR — Casa Electrónica*\\n\\n📱 Cliente: ${telefono_cliente}\\n💬 Bot respondió: ${respuesta_bot.substring(0, 100)}...\\n⏰ ${ahora}`;\n}\nreturn [{ json: { texto_alerta: texto, telefono_dueno: '' } }];"
