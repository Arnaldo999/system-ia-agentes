    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst event = body?.event || '';\nif (event !== 'messages.upsert') { return [{ json: { ignorar: true } }]; }\nconst messageId = body?.data?.key?.id || '';\nconst remoteJid = body?.data?.key?.remoteJid || '';\nconst telefono = remoteJid.replace('@s.whatsapp.net', '').replace('@g.us', '');\nconst msgData = body?.data?.message || {};\nconst mensaje = msgData?.conversation || msgData?.extendedTextMessage?.text || msgData?.imageMessage?.caption || '';\nconst messageType = body?.data?.messageType || '';\nconst tiene_imagen = ['imageMessage', 'documentMessage'].includes(messageType);\nconst es_admin = false;\nconst from_me = body?.data?.key?.fromMe || false;\nif (from_me || remoteJid.includes('@g.us')) { return [{ json: { ignorar: true } }]; }\nif (!remoteJid.endsWith('@s.whatsapp.net')) { return [{ json: { ignorar: true } }]; }\nif (!mensaje.trim()) { return [{ json: { ignorar: true } }]; }\nreturn [{ json: { telefono, mensaje: mensaje.trim(), tiene_imagen, es_admin, ignorar: false, messageId } }];"
      },
      "id": "normalizar-payload",
      "name": "🔧 Normalizar Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 304]
